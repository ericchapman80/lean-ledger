{
  "name": "lean-ledger",
  "version": "0.1.0",
  "description": "Personal macro accountability ledger — track protein/fat/carbs against goal-based targets",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:local": "dotenv -o -e .env.local -- next dev",
    "dev:preview": "dotenv -o -e .env.preview.local -- next dev",
    "dev:prod": "dotenv -o -e .env.production.local -- next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "init-db": "node scripts/init-db.mjs",
    "init-db:local": "dotenv -o -e .env.local -- node scripts/init-db.mjs",
    "init-db:preview": "dotenv -o -e .env.preview.local -- node scripts/init-db.mjs",
    "init-db:prod": "node scripts/confirm-init-db-prod.mjs && dotenv -o -e .env.production.local -- node scripts/init-db.mjs",
    "migrate-db": "node scripts/migrate-db.mjs",
    "migrate-db:local": "dotenv -o -e .env.local -- node scripts/migrate-db.mjs",
    "migrate-db:preview": "dotenv -o -e .env.preview.local -- node scripts/migrate-db.mjs",
    "migrate-db:prod": "node scripts/confirm-migrate-db-prod.mjs && dotenv -o -e .env.production.local -- node scripts/migrate-db.mjs",
    "auth:claim-owner": "node scripts/claim-owner.mjs",
    "auth:claim-owner:local": "dotenv -o -e .env.local -- node scripts/claim-owner.mjs",
    "auth:claim-owner:preview": "dotenv -o -e .env.preview.local -- node scripts/claim-owner.mjs",
    "auth:claim-owner:prod": "node scripts/confirm-claim-owner-prod.mjs && dotenv -o -e .env.production.local -- node scripts/claim-owner.mjs",
    "auth:verify-owner": "node scripts/verify-owner-claim.mjs",
    "auth:verify-owner:local": "dotenv -o -e .env.local -- node scripts/verify-owner-claim.mjs",
    "auth:verify-owner:preview": "dotenv -o -e .env.preview.local -- node scripts/verify-owner-claim.mjs",
    "auth:verify-owner:prod": "dotenv -o -e .env.production.local -- node scripts/verify-owner-claim.mjs",
    "db:export": "node scripts/export-db.mjs",
    "db:restore": "node scripts/restore-db.mjs",
    "db:copy": "node scripts/copy-db.mjs",
    "smoke": "node scripts/smoke-test.mjs"
  },
  "dependencies": {
    "@auth/neon-adapter": "^1.11.2",
    "@neondatabase/serverless": "^1.1.0",
    "@zxing/browser": "^0.2.0",
    "date-fns": "^3.6.0",
    "next": "^15.0.3",
    "next-auth": "^5.0.0-beta.31",
    "pg": "^8.21.0",
    "postgres": "^3.4.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.13.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.1",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.0.8",
    "dotenv": "^17.4.2",
    "dotenv-cli": "^11.0.0",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.0.3",
    "jsdom": "^25.0.1",
    "vitest": "^4.0.8"
  },
  "engines": {
    "node": ">=18.18.0"
  },
  "overrides": {
    "esbuild": "^0.25.0",
    "postcss": "^8.5.10",
    "vite": "^8.0.16"
  }
}
