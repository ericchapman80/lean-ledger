{
  "name": "lean-ledger",
  "version": "0.1.0",
  "description": "Personal macro accountability ledger — track protein/fat/carbs against goal-based targets",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:local": "dotenv -e .env.local -- next dev",
    "dev:preview": "dotenv -e .env.preview.local -- next dev",
    "dev:prod": "dotenv -e .env.production.local -- next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "init-db": "node scripts/init-db.mjs",
    "init-db:local": "dotenv -e .env.local -- node scripts/init-db.mjs",
    "init-db:preview": "dotenv -e .env.preview.local -- node scripts/init-db.mjs",
    "init-db:prod": "node scripts/confirm-init-db-prod.mjs && dotenv -e .env.production.local -- node scripts/init-db.mjs",
    "migrate-db": "node scripts/migrate-db.mjs",
    "db:export": "node scripts/export-db.mjs",
    "db:restore": "node scripts/restore-db.mjs",
    "db:copy": "node scripts/copy-db.mjs",
    "smoke": "node scripts/smoke-test.mjs"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "@zxing/browser": "^0.2.0",
    "date-fns": "^3.6.0",
    "next": "^15.0.3",
    "postgres": "^3.4.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.13.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.1",
    "@vitejs/plugin-react": "^4.3.3",
    "@vitest/coverage-v8": "^2.1.9",
    "dotenv": "^17.4.2",
    "dotenv-cli": "^11.0.0",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.0.3",
    "jsdom": "^25.0.1",
    "vitest": "^2.1.4"
  },
  "engines": {
    "node": ">=18.18.0"
  }
}
