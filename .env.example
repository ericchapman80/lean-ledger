# DATABASE_URL is loaded from the env file used by the current command.
#
# Local Postgres (.env.local):
# DATABASE_URL=postgresql://localhost:5432/lean_ledger
#
# Neon preview / QA (.env.preview.local):
# DATABASE_URL=postgresql://neondb_owner:preview-password@ep-preview.neon.tech/neondb?sslmode=require
#
# Neon production (.env.production.local locally, Vercel Production in hosted deploys):
# DATABASE_URL=postgresql://neondb_owner:prod-password@ep-production.neon.tech/neondb?sslmode=require
#
# Keep preview and production on separate Neon branches or databases.
DATABASE_URL=

# Google auth groundwork stays off until you intentionally cut over.
AUTH_ENABLED=false
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_DEBUG=false
AUTH_OWNER_EMAIL=
AUTH_OWNER_NAME=
AUTH_OWNER_USER_ID=1
AUTH_OWNER_VERIFY_EMAIL=true
# AUTH_URL=https://lean-ledger.vercel.app
# AUTH_TRUST_HOST=true
