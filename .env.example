# Postgres connection string. Same driver (postgres / porsager) speaks to both.
#
# Option A — Neon (cloud, recommended for prod):
# DATABASE_URL=postgresql://neondb_owner:abc123@ep-cool-name.us-east-2.aws.neon.tech/neondb?sslmode=require
#
# Option B — Local Postgres (offline dev, no internet required):
# DATABASE_URL=postgresql://localhost:5432/lean_ledger
